---
import Layout from '../layouts/Layout.astro';
import { home } from '../config/meta.json';
import Hero from '../components/sections/Hero.astro';
import AboutMe from '../components/sections/AboutMe.astro';
import Experience from '../components/sections/Experience.astro';
import Projects from '../components/sections/Projects.astro';
import ContactMe from '../components/sections/ContactMe.astro';

---

<Layout title={home.title} description={home.description} keywords={home.keywords}>
    <Hero />
    <AboutMe />
    <Experience />
    <Projects />
    <ContactMe /> 
</Layout>
