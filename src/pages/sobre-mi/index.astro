---
import Layout from "../../layouts/Layout.astro";
import { aboutMe } from '../../config/meta.json'
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";
import HeaderPage from "../../components/layout/HeaderPage.astro";
import MyPhoto from "../../components/media/MyPhoto.astro";
import SoftSkillsRating from "../../components/sections/SoftSkillsRating.astro";
import Blockquote from "../../components/sections/Blockquote.astro";
import TechStack from "../../components/sections/TechStack.astro";
import Experience from "../../components/sections/Experience.astro";
import Education from "../../components/sections/Education.astro";
import Hobbies from "../../components/sections/Hobbies.astro";
import ContactMe from "../../components/sections/ContactMe.astro";

const {title, description, keywords} = aboutMe

const blockquote = {
    quote: "En un entorno ágil, la única constante es el cambio.",
    author: {
        photo: "https://scrumexpansion.org/creators/jeff-sutherland/jeff-sutherland.jpg",
        name: "Jeff Sutherland",
        occupation: "CEO for Scrum Inc"
    }
}

const path = Astro.url.pathname
const fullPath = path.split('/').filter(Boolean)

export const prerender = true
---

<Layout title={title} description={description} keywords={keywords}>
    <HeaderPage title="Sobre Mi">
        <Breadcrumbs fullPath={fullPath} label="Sobre mí"/>
    </HeaderPage>
    <div class="container mx-auto p-5 tablet:p-10 lg:p-20">
        <section class="max-w-6xl grid grid-cols-1 tablet:grid-cols-2 gap-4 justify-center items-center">
            <div class="flex justify-center items-center">
                <MyPhoto />
            </div>
            <div class="flex flex-col justify-center items-center text-center gap-2 tablet:text-left">
                <div class="prose text-medium-gray dark:text-plomo">
                    <p>
                        Tengo 1 año de experiencia realizando distintas aplicaciones de software como programador, siendo parte de las reuniones con distintos clientes buscando conocer sus necesidades y requerimientos, con esto se inicia la planificación del proceso de desarrollo y la delegación de obligaciones.
                    </p>
                    <p>
                        Me especializo en el diseño de interfaz, el uso de la metodología MERN para proyectos escalables y prefiero Headless CRM para proyectos más potentes. Suelo organizarme de la delegación de funciones, la construcción del código y la comunicación con los clientes.
                    </p>
                </div>
            </div> 
        </section>
        <Blockquote quote={blockquote.quote} author={blockquote.author} />
        <section class="py-10 px-8 max-w-6xl mx-auto grid grid-cols-1 tablet:grid-cols-2 gap-4 place-items-center justify-around">
            <SoftSkillsRating />
            <TechStack />
        </section>
        <Experience />
        <Education />
        <Hobbies />
    </div>
    <ContactMe />
</Layout>