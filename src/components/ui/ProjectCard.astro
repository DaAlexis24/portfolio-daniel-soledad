---
import { getCollection } from "astro:content";
import Button from './Button.astro';
const projects = await getCollection('projects')
---
{
    projects.map((project: { slug: any; data: any; }) => {
        const {slug, data} = project
        const {title, img, description, stack, urls} = data

        return (
        <article aria-label={title} class="group flex w-full flex-col p-6 border max-w-sm tablet:max-w-lg lg:max-w-2xl mx-auto overflow-hidden rounded-2xl bg-light-blue dark:bg-menu-dota border-plomo dark:border-acero transition-all duration-300 ease-in hover:-translate-y-1 hover:border-sea-blue hover:shadow-2xs hover:shadow-radiant hover:dark:border-dire hover:dark:shadow-light-dire">
            <a href={`proyectos/${slug}`} class="mb-2">
                <img src={`/${img}`} alt={title} class="h-52 w-full object-cover rounded-2xl"/>
            </a>
            <div class="flex flex-col p-3">
                <h3 class="mb-4 text-2xl leading-tight">{title}</h3>
                <p class="mb-4 text-light-blue dark:text-light-dire text-sm">{description}</p>
                <div class="flex grow gap-4">
                    {stack.map((item:any) => {
                        return (
                            <img class="w-5 h-5" src={`/${item}`} alt="Icon" />
                        )
                    })}
                </div>
                <div class="flex gap-2">
                    if(urls.demo){
                        <Button type="solid" url={urls.demo}>Demo</Button>
                    }
                    if(urls.code){
                        <Button type="solid" url={urls.code}>
                            Código
                        </Button>
                    }
                </div>
            </div>
        </article>
    )
    })
}