---
import { ArrowBigLeft, ArrowBigRight } from '@lucide/astro';

interface Gallery {
    title: string,
    image: string,
}

interface Props{
    gallery: Gallery[];
    id?: string;
}

const {gallery , id = 'carousel'} = Astro.props
---
<div id={id} class="relative w-full">
    <div class="relative w-full p-2 overflow-hidden aspect-4/3">
        {
            gallery.map((item, index) => (
                <div
                    class={`absolute inset-0 flex items-center justify-center p-2 transition-opacity duration-700 ease-in-out ${index === 0 ? "opacity-100" : "opacity-0 pointer-events-none"}`}
                    data-carousel-item
                >
                    <img
                        src={`/${item.image}`}
                        class="w-full h-full object-contain border dark:border-none rounded-base"
                        alt={item.title}
                        width={800}
                        height={600}
                        loading="lazy"
                    />
                </div>
            ))
        }
    </div>

    <div class="absolute z-30 flex -translate-x-1/2 space-x-3 rtl:space-x-reverse bottom-5 left-1/2">
        {
            gallery.map((_, index) => (
                <button
                    type="button"
                    class={`w-3 h-3 rounded-full transition-colors ${index === 0 ? "bg-black" : "bg-black/50"}`}
                    aria-label={`Slide ${index + 1}`}
                    data-carousel-indicator
                />
            ))
        }
    </div>

    <button type="button" data-carousel-prev aria-label="Anterior" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none focus-visible:ring-2 focus-visible:ring-sea-blue dark:focus-visible:ring-dire focus-visible:ring-offset-2 rounded-lg">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full text-white bg-gray-800/30 group-hover:bg-sea-blue/50 dark:group-hover:bg-ancient/60">
            <ArrowBigLeft size={20} />
        </span>
    </button>

    <button type="button" data-carousel-next aria-label="Siguiente" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none focus-visible:ring-2 focus-visible:ring-sea-blue dark:focus-visible:ring-dire focus-visible:ring-offset-2 rounded-lg">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full text-white bg-gray-800/30 group-hover:bg-sea-blue/50 dark:group-hover:bg-ancient/60">
            <ArrowBigRight size={20}/>
        </span>
    </button>
</div>

<script>
  function initCarousels() {
    document.querySelectorAll("[data-carousel-prev]").forEach((prevBtn) => {
      const carousel = prevBtn.closest("[id]");
      if (!carousel) return;

      const items = carousel.querySelectorAll("[data-carousel-item]");
      const indicators = carousel.querySelectorAll("[data-carousel-indicator]");
      let current = 0;

      function goTo(index) {
        items[current].classList.remove("opacity-100");
        items[current].classList.add("opacity-0", "pointer-events-none");
        indicators[current].classList.remove("bg-black");
        indicators[current].classList.add("bg-black/50");

        // Muestra el nuevo
        current = index;
        items[current].classList.add("opacity-100");
        items[current].classList.remove("opacity-0", "pointer-events-none");
        indicators[current].classList.add("bg-black");
        indicators[current].classList.remove("bg-black/50");
      }

      prevBtn.addEventListener("click", () => {
        goTo(current === 0 ? items.length - 1 : current - 1);
      });

      carousel.querySelector("[data-carousel-next]")?.addEventListener("click", () => {
        goTo(current === items.length - 1 ? 0 : current + 1);
      });

      indicators.forEach((btn, i) => {
        btn.addEventListener("click", () => goTo(i));
      });
    });
  }

  initCarousels();
  document.addEventListener("astro:page-load", initCarousels);
</script>