---
import type { SvgComponent } from 'astro/types'

type Item = {
    label: string,
    icon: SvgComponent
}

type itemsList = Array<Item>

export interface Props {
    itemsList: itemsList
}

const {itemsList} = Astro.props
---

<h3 class="mb-4 font-medium">Tipo de proyecto</h3>
<ul class="grid grid-cols-2 md:grid-cols-3 tablet:grid-cols-1 w-full tablet:w-fit border border-default rounded-2xl dark:border-white">
    {
        itemsList.map((item) => {
            const Icon = item.icon
            return (
            <li class="filter-checkbox w-full border-b flex border-default px-3 last:border-b-0 dark:border-white">
                <div class="inline-flex justify-around items-center p-3 cursor-pointer dark:text-plata">
                    <input id={`list-radio-${item.label.toLowerCase()}`} type="radio" value={item.label} name="list-radio" class="w-4 h-4 text-plate bg-neutral-secondary-medium rounded-full checked:bg-bright-blue checked:border-bright-blue focus:ring-2 focus:outline-none focus:ring-brand-subtle border border-default appearance-none" data-filter={item.label.toLowerCase()}>
                    <label for={`list-radio-${item.label.toLowerCase()}`} class="inline-flex items-center w-full gap-x-1.5 select-none ms-2 text-sm font-medium text-heading">
                        {item.label}
                        <Icon class="text-bright-blue dark:text-orange w-4 h-4"/>
                    </label>
                </div>
            </li>    
            )
        })
    }
                </ul>

<style>
    .filter-checkbox input[type="radio"] {
        -webkit-appearance: none;
        appearance: none;
        border-radius: 50%;
        flex-shrink: 0;
        min-width: 1rem;
        min-height: 1rem;
    }
</style>
