---
import { Star } from "@lucide/astro";
import { hobbies } from '../../../config/content.json'
import MyFavoritesCard from "./MyFavoritesCard.astro";
---

<section class="relative w-full col-span-1 tablet:col-span-1 xl:col-span-2 mx-auto rounded-2xl bg-light-blue dark:bg-menu-dota p-5 tablet:p-8 shadow-xl shadow-black/40 ring-1 ring-white/5" aria-label="Galería de imágenes" >
    <div class="flex items-end gap-3 mb-4">
        <span class="w-10 h-10 tablet:w-15 tablet:h-15 lg:w-20 lg:h-20 flex items-center justify-center rounded-2xl bg-linear-to-br from-radiant to-sea-blue dark:from-dire dark:to-gray-700 hover:animate-scale transition-colors text-light-gray duration-300 ease-in-out">
            <Star size={30}/>
        </span>
        <h3 class="text-lg tablet:text-2xl lg:text-3xl xl:text-5xl text-dark-blue dark:text-plata">Mis Favoritos</h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
        {
            hobbies.map((item) => {
                return(
                    <MyFavoritesCard title={item.title} format={item.format} image={item.image} />
                )
            })
        }
    </div>
</section>
