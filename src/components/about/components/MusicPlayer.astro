---
import {
    Play,
    Pause,
    SkipBack,
    SkipForward,
    Shuffle,
    Volume2,
    VolumeX,
} from "@lucide/astro";
---

<section
    class="player-card relative w-full max-w-sm md:max-w-md tablet:max-w-lg mx-auto rounded-2xl bg-light-blue dark:bg-menu-dota p-5 tablet:p-6 shadow-xl shadow-black/40 ring-1 ring-white/5"   
    aria-label="Reproductor de música"
>
    <div
        class="relative aspect-square w-full overflow-hidden rounded-xl bg-linear-to-br from-dire/50 to-hard-radiant/50 ring-1 ring-white/10"
    >
        <img
            id="mp-cover"
            class="h-full w-full object-cover transition-opacity duration-300 opacity-0"
            alt="Portada del disco"
        />
        <div
            id="mp-cover-skeleton"
            class="absolute inset-0 animate-pulse bg-white/5"
        >
        </div>
        <p
            id="mp-error"
            class="absolute inset-0 hidden items-center justify-center p-4 text-center text-sm text-dire bg-black/70"
        >
            No se pudo cargar la playlist
        </p>
    </div>

    <h3
        id="mp-title"
        class="mt-4 text-lg tablet:text-xl font-semibold text-white truncate"
    >
        —
    </h3>
    <p id="mp-artist" class="text-sm text-medium-gray/80 dark:text-plata/80 truncate">—</p>

    <div
        class="mt-4 flex items-center gap-2 text-xs text-medium-gray/80 dark:text-plata/80 font-montserrat select-none"
    >
        <span id="mp-current-time">0:00</span>
        <div
            id="mp-progress-track"
            role="slider"
            aria-label="Progreso de la canción"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            tabindex="0"
            class="group relative h-1 flex-1 cursor-pointer rounded-full bg-plomo dark:bg-white/10"
        >
            <div
                id="mp-progress-fill"
                class="absolute inset-y-0 left-0 rounded-full bg-linear-to-r from-bright-blue to-sea-blue dark:from-dire dark:to-light-dire"
                style="width:0%"
            >
            </div>
            <div
                id="mp-progress-thumb"
                class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 h-3 w-3 rounded-full bg-hard-radiant dark:bg-white shadow opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
                style="left:0%"
            >
            </div>
        </div>
        <span id="mp-duration">0:00</span>
    </div>

    <div class="mt-5 flex items-center justify-between gap-2">
        <button
            id="mp-shuffle"
            type="button"
            aria-label="Mezclar"
            class="text-bright-blue dark:text-plata/70 hover:text-sea-blue dark:hover:text-white p-2 transition"
        >
            <Shuffle size={20} class="h-4 w-4 tablet:h-5 tablet:w-5" />
        </button>
        <button
            id="mp-prev"
            type="button"
            aria-label="Anterior"
            class="text-medium-gray dark:text-white p-2 hover:scale-110 transition-transform"
        >
            <SkipBack size={22} class="h-5 w-5 tablet:h-6 tablet:w-6" />
        </button>
        <button
            id="mp-play"
            type="button"
            aria-label="Reproducir o pausar"
            class="grid p-2.5 place-items-center rounded-full bg-dark-blue hover:bg-bright-blue dark:bg-orange dark:hover:bg-dire/90 text-white shadow-lg shadow-dark-blue/40 dark:shadow-orange/40 hover:scale-105 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
            <span id="mp-icon-play" class="block"><Play size={26} class="h-7 w-7 tablet:h-8 tablet:w-8" /></span>
            <span id="mp-icon-pause" class="hidden"><Pause size={26} class="h-7 w-7 tablet:h-8 tablet:w-8" /></span>
        </button>
        <button
            id="mp-next"
            type="button"
            aria-label="Siguiente"
            class="text-medium-gray dark:text-white p-2 hover:scale-110 transition-transform"
        >
            <SkipForward size={22} class="h-5 w-5 tablet:h-6 tablet:w-6" />
        </button>

        <div class="flex items-center gap-1.5">
            <button
                id="mp-volume-btn"
                type="button"
                aria-label="Silenciar o activar sonido"
                class="text-bright-blue dark:text-plata/70 hover:text-sea-blue dark:hover:text-white p-2 transition"
            >
                <span id="mp-icon-vol-on" class="block"
                    ><Volume2 size={20} class="h-4 w-4 tablet:h-5 tablet:w-5" /></span
                >
                <span id="mp-icon-vol-off" class="hidden"
                    ><VolumeX size={20} class="h-4 w-4 tablet:h-5 tablet:w-5" /></span
                >
            </button>
            <input
                id="mp-volume"
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="0.7"
                aria-label="Volumen"
                class="hidden xl:block w-16 accent-dark-blue dark:accent-dire"
            />
        </div>
    </div>
    <audio id="mp-audio" preload="metadata" crossorigin="anonymous"></audio>
</section>

<script>
    import type { Playlist } from "../../../types/music";

    const LS_KEY = "music-player-state-v1";
    const PLAYLIST_URL = '/api/playlist';

    type Persisted = {
        cursor: number;
        position: number;
        isShuffle: boolean;
        volume: number;
        isMuted: boolean;
    };

    type State = {
        playlist: Playlist | null;
        queue: number[];
        cursor: number;
        isPlaying: boolean;
        isShuffle: boolean;
        isMuted: boolean;
        volume: number;
        lastPersistSec: number;
    };

    const state: State = {
        playlist: null,
        queue: [],
        cursor: 0,
        isPlaying: false,
        isShuffle: false,
        isMuted: false,
        volume: 0.7,
        lastPersistSec: -1,
    };

    const $ = <T extends HTMLElement>(id: string): T => {
        const el = document.getElementById(id);
        if (!el) throw new Error(`Elemento #${id} no encontrado`);
        return el as T;
    };

    const fmt = (s: number): string => {
        if (!isFinite(s) || s < 0) return "0:00";
        const m = Math.floor(s / 60);
        const sec = Math.floor(s % 60);
        return `${m}:${String(sec).padStart(2, "0")}`;
    };

    function showError(msg: string) {
        const errEl = $("mp-error") as HTMLParagraphElement;
        errEl.textContent = msg;
        errEl.classList.remove("hidden");
        errEl.classList.add("flex");
    }

    function hideError() {
        const errEl = $("mp-error") as HTMLParagraphElement;
        errEl.classList.add("hidden");
        errEl.classList.remove("flex");
    }

    function loadSong(queueIndex: number) {
        if (!state.playlist) return;
        const realIndex = state.queue[queueIndex];
        const item = state.playlist.songs[realIndex];
        if (!item) return;
        const song = item.song;

        const audio = $("mp-audio") as HTMLAudioElement;
        const cover = $("mp-cover") as HTMLImageElement;
        const skeleton = $("mp-cover-skeleton") as HTMLDivElement;
        const title = $("mp-title") as HTMLHeadingElement;
        const artist = $("mp-artist") as HTMLParagraphElement;

        skeleton.classList.remove("hidden");
        cover.style.opacity = "0";
        cover.alt = `Portada: ${song.title} — ${song.artist}`;
        cover.onload = () => {
            cover.style.opacity = "1";
            skeleton.classList.add("hidden");
        };
        cover.onerror = () => {
            skeleton.classList.add("hidden");
        };
        cover.src = song.image_url;

        audio.src = song.audio_url;
        audio.load();

        title.textContent = song.title;
        title.title = song.title;
        artist.textContent = song.artist;
        artist.title = song.artist;

        ($("mp-progress-fill") as HTMLDivElement).style.width = "0%";
        ($("mp-progress-thumb") as HTMLDivElement).style.left = "0%";
        ($("mp-current-time") as HTMLSpanElement).textContent = "0:00";
        ($("mp-duration") as HTMLSpanElement).textContent = "0:00";
        ($("mp-progress-track") as HTMLDivElement).setAttribute(
            "aria-valuenow",
            "0",
        );
    }

    function swapPlayIcon(isPlaying: boolean) {
        ($("mp-icon-play") as HTMLSpanElement).classList.toggle(
            "hidden",
            isPlaying,
        );
        ($("mp-icon-pause") as HTMLSpanElement).classList.toggle(
            "hidden",
            !isPlaying,
        );
    }

    function swapVolumeIcon(isMuted: boolean) {
        ($("mp-icon-vol-on") as HTMLSpanElement).classList.toggle(
            "hidden",
            isMuted,
        );
        ($("mp-icon-vol-off") as HTMLSpanElement).classList.toggle(
            "hidden",
            !isMuted,
        );
    }

    function play() {
        const audio = $("mp-audio") as HTMLAudioElement;
        const p = audio.play();
        if (p && typeof p.then === "function") {
            p.catch((e) => {
                console.warn("No se pudo reproducir:", e);
                state.isPlaying = false;
                swapPlayIcon(false);
            });
        }
    }

    function pause() {
        const audio = $("mp-audio") as HTMLAudioElement;
        audio.pause();
    }

    function togglePlay() {
        if (state.isPlaying) pause();
        else play();
    }

    function next() {
        if (!state.playlist || state.queue.length === 0) return;
        state.cursor = (state.cursor + 1) % state.queue.length;
        loadSong(state.cursor);
        play();
    }

    function prev() {
        if (!state.playlist || state.queue.length === 0) return;
        const audio = $("mp-audio") as HTMLAudioElement;
        if (audio.currentTime > 3) {
            audio.currentTime = 0;
            return;
        }
        state.cursor =
            state.cursor === 0
                ? state.queue.length - 1
                : state.cursor - 1;
        loadSong(state.cursor);
        play();
    }

    function reshuffleQueue() {
        if (!state.playlist) return;
        const current = state.queue[state.cursor];
        const rest = state.queue
            .filter((_, i) => i !== state.cursor)
            .sort(() => Math.random() - 0.5);
        state.queue = [current, ...rest];
        state.cursor = 0;
    }

    function toggleShuffle() {
        state.isShuffle = !state.isShuffle;
        ($("mp-shuffle") as HTMLButtonElement).classList.toggle(
            "text-medium-gray",
            state.isShuffle,
        );
        if (state.isShuffle) reshuffleQueue();
        persist();
    }

    function toggleMute() {
        const audio = $("mp-audio") as HTMLAudioElement;
        state.isMuted = !state.isMuted;
        audio.muted = state.isMuted;
        swapVolumeIcon(state.isMuted);
        persist();
    }

    function setVolume(v: number) {
        const audio = $("mp-audio") as HTMLAudioElement;
        const clamped = Math.max(0, Math.min(1, v));
        state.volume = clamped;
        audio.volume = clamped;

        if (clamped > 0 && state.isMuted) {
            state.isMuted = false;
            audio.muted = false;
            swapVolumeIcon(false);
        } else if (clamped === 0 && !state.isMuted) {
            state.isMuted = true;
            audio.muted = true;
            swapVolumeIcon(true);
        }
        persist();
    }

    function persist() {
        try {
            const audio = $("mp-audio") as HTMLAudioElement;
            const data: Persisted = {
                cursor: state.cursor,
                position: isFinite(audio.currentTime) ? audio.currentTime : 0,
                isShuffle: state.isShuffle,
                volume: state.volume,
                isMuted: state.isMuted,
            };
            localStorage.setItem(LS_KEY, JSON.stringify(data));
        } catch {
            // ignore quota / disabled storage
        }
    }

    function readPersisted(): Persisted | null {
        try {
            const raw = localStorage.getItem(LS_KEY);
            if (!raw) return null;
            const s = JSON.parse(raw) as Partial<Persisted>;
            return {
                cursor: typeof s.cursor === "number" ? s.cursor : 0,
                position: typeof s.position === "number" ? s.position : 0,
                isShuffle: !!s.isShuffle,
                volume:
                    typeof s.volume === "number"
                        ? Math.max(0, Math.min(1, s.volume))
                        : 0.7,
                isMuted: !!s.isMuted,
            };
        } catch {
            return null;
        }
    }

    function applyStateToDOM() {
        const audio = $("mp-audio") as HTMLAudioElement;
        audio.volume = state.isMuted ? 0 : state.volume;
        audio.muted = state.isMuted;
        ($("mp-volume") as HTMLInputElement).value = String(state.volume);
        swapVolumeIcon(state.isMuted);
        ($("mp-shuffle") as HTMLButtonElement).classList.toggle(
            "text-medium-gray",
            state.isShuffle,
        );
        swapPlayIcon(state.isPlaying);
    }

    function restorePersistedState(): void {
        const s = readPersisted();
        if (!s) {
            applyStateToDOM();
            loadSong(0);
            return;
        }

        state.isShuffle = s.isShuffle;
        state.volume = s.volume;
        state.isMuted = s.isMuted;

        applyStateToDOM();

        if (state.playlist) {
            const maxCursor = state.playlist.songs.length - 1;
            state.cursor = Math.max(0, Math.min(maxCursor, s.cursor));
            loadSong(state.cursor);

            if (s.position > 0) {
                const audio = $("mp-audio") as HTMLAudioElement;
                const apply = () => {
                    if (isFinite(audio.duration) && audio.duration > 0) {
                        audio.currentTime = Math.min(
                            s.position,
                            audio.duration,
                        );
                    } else {
                        audio.currentTime = s.position;
                    }
                    audio.removeEventListener("loadedmetadata", apply);
                };
                audio.addEventListener("loadedmetadata", apply);
                if (audio.readyState >= 1) apply();
            }
        }
    }

    function bindEvents() {
        $("mp-play").addEventListener("click", togglePlay);
        $("mp-next").addEventListener("click", next);
        $("mp-prev").addEventListener("click", prev);
        $("mp-shuffle").addEventListener("click", toggleShuffle);
        $("mp-volume-btn").addEventListener("click", toggleMute);
        ($("mp-volume") as HTMLInputElement).addEventListener("input", (e) => {
            const v = parseFloat((e.target as HTMLInputElement).value);
            if (!isNaN(v)) setVolume(v);
        });

        const audio = $("mp-audio") as HTMLAudioElement;
        const durationEl = $("mp-duration") as HTMLSpanElement;
        const fillEl = $("mp-progress-fill") as HTMLDivElement;
        const thumbEl = $("mp-progress-thumb") as HTMLDivElement;
        const currentEl = $("mp-current-time") as HTMLSpanElement;
        const trackEl = $("mp-progress-track") as HTMLDivElement;

        audio.addEventListener("loadedmetadata", () => {
            durationEl.textContent = fmt(audio.duration);
        });
        audio.addEventListener("durationchange", () => {
            durationEl.textContent = fmt(audio.duration);
        });
        audio.addEventListener("timeupdate", () => {
            if (!isFinite(audio.duration) || audio.duration === 0) return;
            const pct = (audio.currentTime / audio.duration) * 100;
            fillEl.style.width = `${pct}%`;
            thumbEl.style.left = `${pct}%`;
            currentEl.textContent = fmt(audio.currentTime);
            trackEl.setAttribute("aria-valuenow", String(Math.round(pct)));
            const cur = Math.floor(audio.currentTime);
            if (cur !== state.lastPersistSec && cur % 5 === 0) {
                state.lastPersistSec = cur;
                persist();
            }
        });
        audio.addEventListener("ended", next);
        audio.addEventListener("play", () => {
            state.isPlaying = true;
            swapPlayIcon(true);
        });
        audio.addEventListener("pause", () => {
            state.isPlaying = false;
            swapPlayIcon(false);
            persist();
        });
        audio.addEventListener("error", () => {
            console.error("Audio error:", audio.error);
            showError(
                "No se pudo cargar el audio. Probá con la siguiente canción.",
            );
        });

        const seek = (clientX: number) => {
            if (!isFinite(audio.duration) || audio.duration === 0) return;
            const r = trackEl.getBoundingClientRect();
            const ratio = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
            audio.currentTime = ratio * audio.duration;
        };
        trackEl.addEventListener("click", (e) =>
            seek((e as MouseEvent).clientX),
        );
        trackEl.addEventListener("keydown", (e) => {
            const k = (e as KeyboardEvent).key;
            if (k === "ArrowLeft") {
                audio.currentTime = Math.max(0, audio.currentTime - 5);
                e.preventDefault();
            } else if (k === "ArrowRight") {
                audio.currentTime = Math.min(
                    isFinite(audio.duration) ? audio.duration : 0,
                    audio.currentTime + 5,
                );
                e.preventDefault();
            } else if (k === " " || k === "Enter") {
                togglePlay();
                e.preventDefault();
            }
        });

        window.addEventListener("beforeunload", persist);
        document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "hidden") persist();
        });
    }

    async function loadPlaylist(): Promise<void> {
        if (!PLAYLIST_URL) {
            showError("Error al cargar la playlist");
            return;
        }
        const res = await fetch(PLAYLIST_URL);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = (await res.json()) as Playlist;
        if (!data.songs || !Array.isArray(data.songs) || data.songs.length === 0) {
            throw new Error("La playlist no tiene canciones");
        }
        state.playlist = data;
        state.queue = data.songs.map((_, i) => i);
    }

    async function init() {
        if (!document.getElementById("mp-play")) return;

        bindEvents();

        if (state.playlist && state.queue.length > 0) {
            applyStateToDOM();
            loadSong(state.cursor);
            return;
        }

        try {
            await loadPlaylist();
            hideError();
            restorePersistedState();
        } catch (e) {
            const msg = e instanceof Error ? e.message : "Error desconocido";
            console.error("MusicPlayer:", e);
            showError(`No se pudo cargar la playlist: ${msg}`);
        }
    }

    document.addEventListener("astro:page-load", init);
</script>
