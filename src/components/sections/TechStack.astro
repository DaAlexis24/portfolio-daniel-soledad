---
const techs = ["astro-light.svg","nextjs.svg","nodejs.svg","prestashop.svg","tailwindcss.svg","typescript.svg","git.svg","visual-studio.svg", "strapi.svg", "python.svg", "java.svg", "netlify.svg", "postgresql.svg", "express.js-light.svg", "prisma-light.svg", "opencode-light.svg"]

const sortedTechs = techs.slice().sort((a,b) => a.localeCompare(b, 'en', {sensitivity: 'base'}))
---
<div class="bg-light-blue dark:bg-menu-dota p-6 border border-plomo dark:border-acero h-full max-w-xl rounded-xl hover:transition-all hover:scale-105">
    <h3 class="text-2xl tablet:text-4xl tracking-wide uppercase mb-4">Tech Stack</h3>
    <div class="grid grid-cols-6 gap-4">
        {sortedTechs.map((tech) => {
            const cleanTech = tech.replace('-light', '');
            const nameTech = cleanTech.charAt(0).toUpperCase() + cleanTech.slice(1).replace(/_|#|-|@|<>/g, " ");
            const finalName = nameTech.split('.')[0];
            return (
                <img src={`/icons/${tech}`} title={finalName} alt={finalName} width={40} height={40} loading="lazy" class="h-10 w-10 object-scale-down drop-shadow-acero"/>
            )
        })}
    </div>
</div>