---
import MyPhoto from '../media/MyPhoto.astro';
import { hero } from '../../config/content.json';
import { socialLinks } from '../../config/site.json';
import Button from '../ui/Button.astro';
import { UserSearchIcon } from '@lucide/astro';
import LinkedinIcon from '../icons/LinkedinIcon.astro';
import GithubIcon from '../icons/GithubIcon.astro';

const iconMap = {
    LinkedIn: LinkedinIcon,
    GitHub: GithubIcon,
};

const {title, professions, abstract} = hero;
---
<section id="hero" class="justify-center" role="presentation">
    <div class="container grid grid-cols-1 max-w-7xl mx-auto px-10 pt-20 tablet:pt-25 sm:grid-cols-[1fr_auto] tablet:grid-cols-[2fr_1fr]">
        <div class="flex flex-col gap-6 max-w-sm mx-auto text-center items-center sm:max-w-md sm:text-left sm:items-start tablet:max-w-3xl lg:max-w-6xl">
            <hgroup>
                <h1 class="flex flex-wrap justify-center text-center items-center md:text-start sm:justify-start gap-2 text-4xl text-dark-blue tablet:text-5xl lg:text-7xl tablet:gap-3 dark:text-dire">Hola, soy <span class="typing" style={`--typing-ch: ${title.length}ch`}>{title}</span></h1>
                <div class="text-decorative">
                    {professions.map((profession) => (
                        <p class="font-semibold text-acero tablet:text-xl dark:text-light-gray">{profession}</p>
                    ))}
                </div>
            </hgroup>
            <p class=" text-gray-500 tablet:text-lg dark:text-neutral-200">{abstract}</p>
            <div class="inline-flex justify-center items-center py-2 space-x-5 overflow-hidden">
                <Button type='solid' url='/sobre-mi'>
                    Conóceme <UserSearchIcon size={16} aria-hidden="true"/>
                </Button>
                {socialLinks.map((social) => {
                    const Icon = iconMap[social.site as keyof typeof iconMap];
                    return (
                        <a href={social.url} target="_blank" rel="noopener noreferrer" title={social.site} aria-label={`${social.site} (se abre en nueva pestaña)`}>
                            <div class="icons text-bright-blue dark:text-dire hover:scale-105">
                                {Icon && <Icon />}
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
        <div class="mt-0 flex justify-center items-center">
            <MyPhoto />
        </div>                
    </div>
</section>

<style>
    .icons{
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .icons svg{
        width: 30px;
        height: 30px;
        fill: currentColor;
        transition: all 0.3s ease-in-out;
    }

    p {
        font-family: system-ui, -apple-system, sans-serif;
    }

    .text-decorative{
        --height: 1.875rem;
        height: var(--height);
        line-height: var(--height);

        overflow: hidden;
    }

    .text-decorative p{
        animation: slide-up 6s infinite;
    }

    @keyframes slide-up {
        0%, 50% {
            transform: translateY(0%);
        }
        55%, 95% {
            transform: translateY(-100%);
        }
    }

    span.typing{
        display: block;
        white-space: nowrap;
        width: var(--typing-ch, 6ch);
        animation: writing 2s steps(10);
        overflow: hidden;
    }

    @keyframes writing {
        from {width: 0;}
    }

    /* Pause animations when section is not in viewport */
    section:not(.in-view) .text-decorative p,
    section:not(.in-view) span.typing {
        animation-play-state: paused;
    }

    @media (prefers-reduced-motion: reduce) {
        .text-decorative p,
        span.typing {
            animation: none;
        }
    }
</style>

<script>
    function initHeroObserver() {
        const hero = document.getElementById('hero');
        if (hero) {
            const observer = new IntersectionObserver(([entry]) => {
                hero.classList.toggle('in-view', entry.isIntersecting);
            }, { threshold: 0 });
            observer.observe(hero);
        }
    }

    document.addEventListener('astro:page-load', initHeroObserver);
    initHeroObserver();
</script>